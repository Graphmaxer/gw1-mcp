{
  "name": "gw1-mcp",
  "version": "0.8.2",
  "private": true,
  "description": "A Guild Wars 1 build compiler for LLMs (MCP server)",
  "license": "MIT",
  "scripts": {
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "test:coverage": "pnpm -r exec vitest run --coverage --coverage.reporter=text",
    "lint": "oxlint packages types",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
