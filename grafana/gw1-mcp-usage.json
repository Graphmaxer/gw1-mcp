      "id": 10,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "## gw1-mcp — what the server actually does, live\nAnonymous per-tool call counts from the [gw1-mcp](https://github.com/Graphmaxer/gw1-mcp) MCP server (Guild Wars 1 build compiler for LLMs). **Tool names only — never arguments, never identities** ([privacy](https://gw1-mcp.graphmaxer.workers.dev/privacy)). Data: Cloudflare Workers Analytics Engine, 90-day retention, sampled (totals use `SUM(_sample_interval)`). This dashboard is versioned code — [see the JSON](https://github.com/Graphmaxer/gw1-mcp/blob/main/grafana/gw1-mcp-usage.json)."
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Tool calls (selected range)",
      "description": "Actual work requested by assistants.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "aft354s7rt3wgf"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "aft354s7rt3wgf"
          },
          "type": "json",
          "source": "url",
          "parser": "backend",
          "format": "table",
          "url": "",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "text/plain",
            "data": "SELECT SUM(_sample_interval) AS calls FROM gw1_mcp_usage WHERE timestamp > toDateTime(${__timeFrom} / 1000) AND timestamp < toDateTime(${__timeTo} / 1000) AND blob1 LIKE 'tool:%'"
          },
          "root_selector": "data",
          "columns": [
            {
              "selector": "calls",
              "text": "calls",
              "type": "number"
            }
          ],
          "filters": [],
          "global_query_id": "",
