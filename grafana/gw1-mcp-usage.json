          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "text/plain",
            "data": "SELECT substring(blob1, 6, 64) AS tool, SUM(_sample_interval) AS calls FROM gw1_mcp_usage WHERE timestamp > toDateTime(${__timeFrom} / 1000) AND timestamp < toDateTime(${__timeTo} / 1000) AND blob1 LIKE 'tool:%' GROUP BY tool ORDER BY calls DESC"
