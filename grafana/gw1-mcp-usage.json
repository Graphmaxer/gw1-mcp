          "url": "",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "text/plain",
            "data": "SELECT round(100 * SUM(if(blob1 NOT LIKE 'tool:%', _sample_interval, 0)) / SUM(_sample_interval), 1) AS pct FROM gw1_mcp_usage WHERE timestamp > toDateTime(${__timeFrom} / 1000) AND timestamp < toDateTime(${__timeTo} / 1000)"
